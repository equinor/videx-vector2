{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "./dist",
    "target": "es6",
    "types": ["vitest/globals"]
  },
  "include": ["src/*", "test/*"],
  "exclude": ["node_modules"]
}
