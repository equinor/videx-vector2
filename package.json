{
  "name": "@equinor/videx-vector2",
  "version": "1.0.53",
  "description": "Vector2 class library written in javascript.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "predocs": "rimraf docs",
    "docs": "typedoc --out docs src",
    "postdocs": "node postdocs.copyfiles.mjs",
    "lint": "eslint --color"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/equinor/videx-vector2.git"
  },
  "keywords": [
    "videx",
    "vector",
    "2d"
  ],
  "author": "Tom Kristian Tjemsland",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/equinor/videx-vector2/issues"
  },
  "homepage": "https://github.com/equinor/videx-vector2#readme",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "rimraf": "^3.0.1",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@equinor/videx-linear-algebra": "^1.0.21"
  }
}
